<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MyClients.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="">

    <ScrollView>
        <VerticalStackLayout Padding="20">

            <FlexLayout
                Direction="Row"
                JustifyContent="Start"
                Wrap="Wrap">

                <Frame
                    Padding="10"
                    HeightRequest="100"
                    WidthRequest="100">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="ClientsButton_Clicked" />
                    </Frame.GestureRecognizers>

                    <VerticalStackLayout VerticalOptions="Center">

                        <Label
                            FontFamily="FontAwesome"
                            FontSize="40"
                            HorizontalOptions="Center"
                            Text="&#xF0C0;" />

                        <Label
                            FontAttributes="Bold"
                            HorizontalOptions="Center"
                            Text="Clientes" />

                    </VerticalStackLayout>
                </Frame>

            </FlexLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
