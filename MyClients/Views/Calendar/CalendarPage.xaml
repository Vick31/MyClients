<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="MyClients.Views.Calendar.CalendarPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Agenda"
    Background="{StaticResource PageBackground}">

    <Grid Margin="10" RowDefinitions="Auto,Auto,Auto,auto,*">

        <Grid Grid.Row="0" Padding="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <VerticalStackLayout>
                <Label
                    FontAttributes="Bold"
                    FontSize="30"
                    Text="📅 Mi Agenda"
                    TextColor="{StaticResource TextPrimary}" />

                <Label
                    FontSize="14"
                    Opacity="0.7"
                    Text="Gestiona tus eventos."
                    TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>

            <Button
                Grid.Column="1"
                Margin="0,0,0,0"
                Clicked="NewReminder_Clicked"
                CornerRadius="100"
                HeightRequest="50"
                Text="➕"
                WidthRequest="50" />
        </Grid>

        <!--  Encabezado  -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto">

            <Button
                Clicked="PreviousMonth_Clicked"
                HeightRequest="35"
                Text="◀"
                TextColor="{StaticResource White}" />

            <Label
                x:Name="lblMonth"
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="18"
                HorizontalTextAlignment="Center"
                TextColor="{StaticResource TextPrimary}"
                TextTransform="Uppercase"
                VerticalTextAlignment="Center" />

            <Button
                Grid.Column="2"
                Clicked="NextMonth_Clicked"
                HeightRequest="35"
                Text="▶"
                TextColor="{StaticResource White}" />

        </Grid>

        <!--  Días de la semana  -->

        <Grid
            Grid.Row="2"
            Margin="0,15,0,10"
            ColumnDefinitions="*,*,*,*,*,*,*">

            <Label
                Grid.Column="0"
                HorizontalTextAlignment="Center"
                Text="L"
                TextColor="{StaticResource TextPrimary}" />
            <Label
                Grid.Column="1"
                HorizontalTextAlignment="Center"
                Text="M"
                TextColor="{StaticResource TextPrimary}" />
            <Label
                Grid.Column="2"
                HorizontalTextAlignment="Center"
                Text="M"
                TextColor="{StaticResource TextPrimary}" />
            <Label
                Grid.Column="3"
                HorizontalTextAlignment="Center"
                Text="J"
                TextColor="{StaticResource TextPrimary}" />
            <Label
                Grid.Column="4"
                HorizontalTextAlignment="Center"
                Text="V"
                TextColor="{StaticResource TextPrimary}" />
            <Label
                Grid.Column="5"
                HorizontalTextAlignment="Center"
                Text="S"
                TextColor="{StaticResource TextPrimary}" />
            <Label
                Grid.Column="6"
                HorizontalTextAlignment="Center"
                Text="D"
                TextColor="{StaticResource TextPrimary}" />

        </Grid>

        <!--  Calendario  -->

        <Border
            Grid.Row="3"
            Padding="10"
            Background="{StaticResource CardBackground}"
            Stroke="{StaticResource BorderColor}"
            StrokeShape="RoundRectangle 15">

            <Grid
                x:Name="CalendarGrid"
                ColumnSpacing="4"
                RowSpacing="4">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="55" />
                    <RowDefinition Height="55" />
                    <RowDefinition Height="55" />
                    <RowDefinition Height="55" />
                    <RowDefinition Height="55" />
                    <RowDefinition Height="55" />
                </Grid.RowDefinitions>

            </Grid>
        </Border>

        <Border
            Grid.Row="4"
            Margin="0,15,0,0"
            Padding="15"
            Background="{StaticResource CardBackground}"
            Stroke="{StaticResource BorderColor}"
            StrokeShape="RoundRectangle 15">

            <VerticalStackLayout>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="📌 Agenda del día"
                        TextColor="{StaticResource TextPrimary}"
                        VerticalOptions="Center"
                        VerticalTextAlignment="Center" />

                    <Label
                        Grid.Column="1"
                        FontSize="14"
                        Opacity="0.7"
                        Text="{Binding SelectedDateText}"
                        TextColor="{StaticResource TextSecondary}"
                        VerticalOptions="Center"
                        VerticalTextAlignment="Center" />
                </Grid>

                <CollectionView Margin="0,10,0,0" ItemsSource="{Binding Reminders}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="0,0,0,8"
                                Padding="12"
                                Background="{StaticResource CardBackground}"
                                BackgroundColor="{StaticResource CardBackground}"
                                Stroke="{StaticResource BorderColor}"
                                StrokeShape="RoundRectangle 12">

                                <VerticalStackLayout>

                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="16"
                                        Text="{Binding Title}"
                                        TextColor="{StaticResource TextPrimary}" />

                                    <Label
                                        FontSize="13"
                                        Text="{Binding Time}"
                                        TextColor="{StaticResource TextSecondary}" />

                                </VerticalStackLayout>

                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>