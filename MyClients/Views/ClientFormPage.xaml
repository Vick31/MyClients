<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MyClients.Views.ClientFormPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Nuevo Cliente">

    <ScrollView>

        <VerticalStackLayout Padding="20" Spacing="20">

            <!--  Encabezado  -->
            <VerticalStackLayout Spacing="5">

                <Label
                    FontAttributes="Bold"
                    FontSize="28"
                    Text="👤 Nuevo Cliente" />

                <Label
                    FontSize="14"
                    Opacity="0.7"
                    Text="Registra la información básica de tu cliente." />

            </VerticalStackLayout>

            <!--  Información  -->
            <Border Padding="20" StrokeShape="RoundRectangle 15">

                <VerticalStackLayout Spacing="15">

                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        HorizontalTextAlignment="Center"
                        Text="👤 Información Personal" />

                    <VerticalStackLayout Spacing="5">

                        <Label FontAttributes="Bold" Text="📝 Nombre" />

                        <Entry
                            x:Name="NameEntry"
                            Placeholder="Ej: Rayito de Luz"
                            TextTransform="Uppercase" />

                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">

                        <Label FontAttributes="Bold" Text="📱 Teléfono" />

                        <Entry
                            x:Name="PhoneEntry"
                            Keyboard="Telephone"
                            MaxLength="10"
                            Placeholder="Ej: 3001234567" />

                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="10">

                        <Label FontAttributes="Bold" Text="🎨 Color identificador" />

                        <CollectionView
                            x:Name="ColorsCollection"
                            HeightRequest="130"
                            SelectionChanged="ColorsCollection_SelectionChanged"
                            SelectionMode="Single">

                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="6" />
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate>

                                    <Border
                                        Margin="4"
                                        BackgroundColor="{Binding Hex}"
                                        HeightRequest="40"
                                        StrokeShape="RoundRectangle 20"
                                        WidthRequest="40" />

                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                        </CollectionView>

                        <Border Padding="10" StrokeShape="RoundRectangle 10">

                            <HorizontalStackLayout Spacing="10">

                                <Border
                                    x:Name="SelectedColorPreview"
                                    Background="#2196F3"
                                    HeightRequest="30"
                                    StrokeShape="RoundRectangle 15"
                                    WidthRequest="30" />

                                <Label
                                    x:Name="SelectedColorLabel"
                                    Text="Azul (#2196F3)"
                                    VerticalOptions="Center" />

                            </HorizontalStackLayout>

                        </Border>

                    </VerticalStackLayout>

                </VerticalStackLayout>

            </Border>

            <!--  Consejo  -->
            <Border Padding="15" StrokeShape="RoundRectangle 10">

                <HorizontalStackLayout Spacing="10">

                    <Label FontSize="24" Text="💡" />

                    <Label Opacity="0.8" Text="Puedes agregar más información del cliente en futuras versiones, como dirección, correo y notas." />

                </HorizontalStackLayout>

            </Border>

            <!--  Botón  -->
            <Button
                x:Name="SaveButton"
                Clicked="SaveButton_Clicked"
                CornerRadius="15"
                HeightRequest="55"
                Text="💾 Guardar Cliente" />

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>