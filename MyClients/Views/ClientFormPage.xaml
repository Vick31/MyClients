<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MyClients.Views.ClientFormPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title=""
    BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>

        <VerticalStackLayout Padding="10" Spacing="20">

            <!--  Encabezado  -->
            <VerticalStackLayout Spacing="5">

                <Label
                    x:Name="lbTitle"
                    FontAttributes="Bold"
                    FontSize="28"
                    Text="👤 Nuevo Cliente"
                    TextColor="{StaticResource TextPrimary}" />

                <Label
                    FontSize="14"
                    Opacity="0.7"
                    Text="Registra la información básica de tu cliente."
                    TextColor="{StaticResource TextSecondary}" />

            </VerticalStackLayout>

            <!--  Información  -->
            <Border
                Padding="10"
                Stroke="{StaticResource BorderColor}"
                StrokeShape="RoundRectangle 15">


                <VerticalStackLayout Spacing="15">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        HorizontalTextAlignment="Center"
                        Text="Información Personal"
                        TextColor="{StaticResource TextPrimary}" />

                    <VerticalStackLayout Spacing="5">

                        <Label
                            FontAttributes="Bold"
                            Text="📝 Nombre"
                            TextColor="{StaticResource TextSecondary}" />

                        <Border
                            Grid.Row="1"
                            Padding="10,5"
                            Background="{StaticResource CardBackground}"
                            Stroke="{StaticResource BorderColor}"
                            StrokeShape="RoundRectangle 15">

                            <Entry
                                x:Name="NameEntry"
                                Placeholder="Ej: Rayito de Luz"
                                TextColor="{StaticResource OffBlack}"
                                TextTransform="Uppercase" />
                        </Border>

                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="5">
                        <Label
                            FontAttributes="Bold"
                            Text="📱 Teléfono"
                            TextColor="{StaticResource TextSecondary}" />

                        <Border
                            Grid.Row="1"
                            Padding="10,5"
                            Background="{StaticResource CardBackground}"
                            Stroke="{StaticResource BorderColor}"
                            StrokeShape="RoundRectangle 15">

                            <Entry
                                x:Name="PhoneEntry"
                                Keyboard="Telephone"
                                MaxLength="10"
                                Placeholder="Ej: 3001234567"
                                TextColor="{StaticResource OffBlack}" />
                        </Border>

                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="10">

                        <Label
                            FontAttributes="Bold"
                            Text="🎨 Color identificador"
                            TextColor="{StaticResource TextSecondary}" />

                        <CollectionView
                            x:Name="ColorsCollection"
                            HeightRequest="130"
                            SelectionChanged="ColorsCollection_SelectionChanged"
                            SelectionMode="Single">

                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="6" />
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate>

                                    <Border
                                        Margin="4"
                                        BackgroundColor="{Binding Hex}"
                                        HeightRequest="40"
                                        StrokeShape="RoundRectangle 20"
                                        WidthRequest="40" />

                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                        </CollectionView>

                        <Border
                            Grid.Row="1"
                            Padding="10,5"
                            Background="{StaticResource CardBackground}"
                            Stroke="{StaticResource BorderColor}"
                            StrokeShape="RoundRectangle 15">

                            <HorizontalStackLayout Spacing="10">

                                <Border
                                    x:Name="SelectedColorPreview"
                                    Background="#2196F3"
                                    HeightRequest="30"
                                    StrokeShape="RoundRectangle 15"
                                    WidthRequest="30" />

                                <Label
                                    x:Name="SelectedColorLabel"
                                    Text="Azul (#2196F3)"
                                    TextColor="{StaticResource OffBlack}"
                                    VerticalOptions="Center" />

                            </HorizontalStackLayout>

                        </Border>

                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!--  Consejo  -->
            <!--<Border
                Padding="15"
                Background="{StaticResource InfoBackground}"
                Stroke="{StaticResource Primary}"
                StrokeShape="RoundRectangle 10">

                <Grid ColumnDefinitions="Auto,*">

                    <Label
                        FontSize="24"
                        Text="💡"
                        VerticalOptions="Center" />

                    <Label
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        LineBreakMode="WordWrap"
                        Opacity="0.8"
                        Text="Puedes agregar más información del cliente en futuras versiones, como dirección, correo y notas."
                        TextColor="{StaticResource OffBlack}" />

                </Grid>

            </Border>-->

            <!--  Botón  -->
            <Button
                x:Name="SaveButton"
                BackgroundColor="{StaticResource ButtonSuccess}"
                Clicked="SaveButton_Clicked"
                CornerRadius="15"
                FontAttributes="Bold"
                HeightRequest="55"
                Text="💾 Guardar Cliente"
                TextColor="{StaticResource White}" />

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>