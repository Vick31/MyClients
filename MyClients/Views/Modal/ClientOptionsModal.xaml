<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    x:Class="MyClients.Views.Modal.ClientOptionsPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Color="Transparent">

    <Border
        Padding="20"
        Background="{StaticResource CardBackground}"
        Stroke="{StaticResource BorderColor}"
        StrokeShape="RoundRectangle 20">
        <VerticalStackLayout Spacing="10">
            <Button
                BackgroundColor="{StaticResource ButtonInfo}"
                Clicked="EditClient_Clicked"
                FontAttributes="Bold"
                Text="✏️ Editar Cliente"
                TextColor="{StaticResource White}" />

            <Button
                BackgroundColor="{StaticResource ButtonInfo}"
                Clicked="NewService_Clicked"
                FontAttributes="Bold"
                Text="✂️ Registrar Servicio"
                TextColor="{StaticResource White}" />

            <Button
                BackgroundColor="{StaticResource ButtonInfo}"
                Clicked="ViewHistory_Clicked"
                FontAttributes="Bold"
                Text="📋 Ver Historial"
                TextColor="{StaticResource White}" />

            <Button
                BackgroundColor="{StaticResource ButtonDanger}"
                Clicked="Close_Clicked"
                FontAttributes="Bold"
                Text="Cerrar"
                TextColor="{StaticResource White}" />
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>