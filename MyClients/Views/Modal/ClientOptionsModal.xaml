<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    x:Class="MyClients.Views.Modal.ClientOptionsPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Color="Transparent">

    <Border
        Padding="20"
        Background="Black"
        StrokeShape="RoundRectangle 20">
        <VerticalStackLayout Spacing="10">
            <Button Clicked="EditClient_Clicked" Text="✏️ Editar Cliente" />
            <Button Clicked="NewService_Clicked" Text="✂️ Registrar Servicio" />
            <Button Clicked="ViewHistory_Clicked" Text="📋 Ver Historial" />
            <Button Clicked="Close_Clicked" Text="❌ Cerrar" />
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>