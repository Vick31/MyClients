<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MyClients.Views.ClientsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title=""
    BackgroundColor="{StaticResource PageBackground}">

    <Grid>

        <Grid RowDefinitions="Auto,Auto,Auto,*">

            <!--  Encabezado  -->
            <VerticalStackLayout Grid.Row="0" Padding="20,20,20,10">

                <Label
                    FontAttributes="Bold"
                    FontSize="30"
                    Text="👥 Mis Clientes"
                    TextColor="{StaticResource TextPrimary}" />

                <Label
                    FontSize="14"
                    Opacity="0.7"
                    Text="Gestiona tu cartera de clientes y servicios"
                    TextColor="{StaticResource TextSecondary}" />

                <Label
                    Margin="0,5,0,0"
                    FontSize="13"
                    Opacity="0.6"
                    Text="{Binding Clients.Count, StringFormat='Clientes registrados: {0}'}"
                    TextColor="{StaticResource TextSecondary}" />

            </VerticalStackLayout>

            <!--  Búsqueda  -->
            <Border
                Grid.Row="1"
                Margin="15,0"
                Padding="10,5"
                Background="{StaticResource CardBackground}"
                Stroke="{StaticResource BorderColor}"
                StrokeShape="RoundRectangle 15">

                <Grid ColumnDefinitions="Auto,*">
                    <Label
                        Margin="5,0,10,0"
                        FontSize="18"
                        Text="🔍"
                        TextColor="{StaticResource Primary}"
                        VerticalOptions="Center" />

                    <Entry
                        Grid.Column="1"
                        Placeholder="Buscar cliente..."
                        PlaceholderColor="{StaticResource Gray500}"
                        Text="{Binding SearchText}"
                        TextColor="{StaticResource OffBlack}" />

                </Grid>

            </Border>

            <!--  Mensaje  -->
            <Border
                Grid.Row="2"
                Margin="15,10,15,10"
                Padding="12"
                Background="{StaticResource InfoBackground}"
                Stroke="{StaticResource Primary}"
                StrokeShape="RoundRectangle 10">

                <Grid ColumnDefinitions="Auto,*">

                    <Label
                        FontSize="24"
                        Text="💡"
                        VerticalOptions="Start" />

                    <Label
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        LineBreakMode="WordWrap"
                        Opacity="0.8"
                        Text="Toca un cliente para registrar servicios, consultar historial o editar su información."
                        TextColor="{StaticResource OffBlack}" />

                </Grid>

            </Border>

            <!--  Lista  -->
            <CollectionView
                Grid.Row="3"
                Margin="10,0"
                ItemsSource="{Binding Clients}"
                SelectionMode="None">

                <CollectionView.EmptyView>
                    <VerticalStackLayout
                        Padding="50"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">

                        <Label
                            FontSize="80"
                            HorizontalTextAlignment="Center"
                            Text="👥" />

                        <Label
                            FontAttributes="Bold"
                            FontSize="22"
                            HorizontalTextAlignment="Center"
                            Text="Aún no tienes clientes"
                            TextColor="{StaticResource TextPrimary}" />

                        <Label
                            Margin="20,10,20,0"
                            HorizontalTextAlignment="Center"
                            LineBreakMode="WordWrap"
                            Opacity="0.7"
                            Text="Comienza agregando tu primer cliente para registrar servicios y consultar historiales."
                            TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,5"
                            Padding="15"
                            BackgroundColor="{Binding ColorHex}"
                            Stroke="{StaticResource BorderColor}"
                            StrokeShape="RoundRectangle 18">

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer CommandParameter="{Binding}" Tapped="Client_Tapped" />
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="50,*,Auto">

                                <!--  Avatar  -->
                                <Border
                                    HeightRequest="50"
                                    Stroke="{StaticResource BorderColor}"
                                    StrokeShape="RoundRectangle 25"
                                    WidthRequest="50">

                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="18"
                                        HorizontalOptions="Center"
                                        Text="👤"
                                        VerticalOptions="Center" />

                                </Border>

                                <!--  Datos  -->
                                <VerticalStackLayout
                                    Grid.Column="1"
                                    Margin="10,0,0,0"
                                    VerticalOptions="Center">

                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="16"
                                        Text="{Binding Name}" />

                                    <Label
                                        FontSize="13"
                                        Opacity="0.7"
                                        Text="{Binding Phone, StringFormat='📱 {0}'}" />

                                </VerticalStackLayout>

                                <!--  Flecha  -->
                                <Label
                                    Grid.Column="2"
                                    FontSize="24"
                                    Opacity="0.4"
                                    Text="›"
                                    VerticalOptions="Center" />

                            </Grid>
                        </Border>
                    </DataTemplate>

                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!--  Botón flotante  -->
        <Button
            Margin="20"
            Clicked="NewClientButton_Clicked"
            CornerRadius="30"
            FontSize="24"
            HeightRequest="60"
            HorizontalOptions="End"
            Text="➕"
            VerticalOptions="Start"
            WidthRequest="60" />

    </Grid>

</ContentPage>