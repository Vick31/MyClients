<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyClients.Views.ClientActionPage"
             Title="Servicios">
    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="15">

            <Label
                FontAttributes="Bold"
                FontSize="20"
                Text="Programar servicio" />

            <Label Text="Tipo de Acción" />

            <Picker x:Name="ActionTypePicker" Title="Select action">
                <Picker.Items>
                    <x:String>Keratina</x:String>
                    <x:String>Tinte</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="Fecha" />

            <DatePicker x:Name="ActionDatePicker" />

            <Label Text="Comentario" />

            <Editor
                x:Name="NotesEditor"
                AutoSize="TextChanges"
                HeightRequest="120"
                Placeholder="comentario..." />

            <Button
                Clicked="SaveButton_Clicked"
                Text="Guardar Información" />

        </VerticalStackLayout>

    </ScrollView>
</ContentPage>